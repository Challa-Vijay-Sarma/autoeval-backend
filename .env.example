# Backend env (Autoeval-pipeline/.env). The frontend has its own at frontend/.env.

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_MAX_TOKENS=16000

# ---- Storage: "local" or "gcs" ----
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage

# When STORAGE_BACKEND=gcs: must match the bucket name exactly as in Cloud Console / gsutil ls
# (hyphens vs underscores are different buckets), e.g. autoeval_pipeline
GCS_BUCKET=
# Set true for Rapid/zonal buckets (or leave false: first upload auto-detects from GCS 400).
GCS_FORCE_APPENDABLE=false
# Path to the GCP service account JSON key. Only needed for local dev.
# On Cloud Run, the attached service account is used automatically.
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Parallelism ----
# How many episodes evaluate concurrently inside a single run (each thread
# holds one OpenAI request). Default 10. Lower if you hit TPM rate limits.
MAX_PARALLEL_EPISODES=10
# How many zip entries are written to the bucket in parallel during ingest.
# Default 16. Helps a lot on Rapid / HNS buckets where each write is ~1.3s.
INGEST_PARALLELISM=16

# ---- Auth (empty = open access) ----
API_TOKEN=

# ---- CORS: comma-separated origins allowed to call the API ----
# Dev: http://localhost:5173 (Vite). Prod: the deployed frontend URL(s).
CORS_ALLOW_ORIGINS=http://localhost:5173
